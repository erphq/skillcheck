{
  "name": "skillcheck",
  "version": "0.5.0",
  "description": "Static analyzer for Claude Code skills",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skillcheck": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "GOALS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p . && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "tsc -p . --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "claude",
    "skills",
    "linter",
    "static-analysis"
  ],
  "homepage": "https://github.com/erphq/skillcheck",
  "repository": {
    "type": "git",
    "url": "https://github.com/erphq/skillcheck.git"
  },
  "bugs": {
    "url": "https://github.com/erphq/skillcheck/issues"
  }
}
